---
import { t, type Lang } from '~/i18n/utils';

interface Props {
  lang: Lang;
  role: string;
  period: string;
  stack: string[];
  statusKey: 'inDailyProduction' | 'delivered' | 'ongoing';
  statusSuffix?: string;
  liveUrl?: string;
}

const { lang, role, period, stack, statusKey, statusSuffix, liveUrl } = Astro.props;
const d = t(lang);
const statusBase = d.status[statusKey];

const domainMatch = statusSuffix && liveUrl
  ? statusSuffix.match(/([a-z0-9][a-z0-9-]*(?:\.[a-z0-9-]+)+)/i)
  : null;
const suffixBefore = domainMatch ? statusSuffix!.slice(0, domainMatch.index!) : '';
const suffixDomain = domainMatch ? domainMatch[1] : '';
const suffixAfter = domainMatch ? statusSuffix!.slice(domainMatch.index! + suffixDomain.length) : '';
---
<aside class="glass p-6 sticky top-28 self-start text-sm">
  <dl class="grid gap-5">
    <div>
      <dt class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-[var(--font-mono)]">{d.caseMeta.role}</dt>
      <dd class="mt-1.5">{role}</dd>
    </div>
    <div>
      <dt class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-[var(--font-mono)]">{d.caseMeta.period}</dt>
      <dd class="mt-1.5">{period}</dd>
    </div>
    <div>
      <dt class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-[var(--font-mono)]">{d.caseMeta.stack}</dt>
      <dd class="mt-2 flex flex-wrap gap-1.5">{stack.map(s => <span class="chip">{s}</span>)}</dd>
    </div>
    <div>
      <dt class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-[var(--font-mono)]">{d.caseMeta.status}</dt>
      <dd class="mt-1.5 inline-flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-2)] animate-pulse"></span>
        <span>
          {statusBase}
          {statusSuffix && <Fragment>{' · '}</Fragment>}
          {domainMatch ? (
            <Fragment>
              {suffixBefore}
              <a href={liveUrl} target="_blank" rel="noopener" class="underline underline-offset-2 hover:text-[var(--color-accent)] transition-colors">{suffixDomain}</a>
              {suffixAfter}
            </Fragment>
          ) : statusSuffix}
        </span>
      </dd>
    </div>
  </dl>
</aside>
