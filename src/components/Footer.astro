---
import { t, type Lang } from '~/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import Logo from './Logo.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const d = t(lang);

const email = 'hello@astyltsvig.dk';
const github = 'https://github.com/astyltsvig';
const linkedin = 'https://www.linkedin.com/in/astyltsvig/';
---
<footer class="mx-4 md:mx-8 mb-6 mt-24">
  <div class="glass max-w-6xl mx-auto px-6 md:px-10 py-10">
    <div class="grid gap-10 md:grid-cols-[auto_1fr] md:gap-16 items-start">
      <Logo lang={lang} />
      <div class="grid gap-6 md:grid-cols-3 text-sm">
        <div>
          <p class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-[var(--font-mono)]">Contact</p>
          <ul class="mt-3 space-y-1.5">
            <li><a href={`mailto:${email}`}>{email}</a></li>
            <li><a href={github} rel="me noopener" target="_blank">GitHub ↗</a></li>
            <li><a href={linkedin} rel="me noopener" target="_blank">LinkedIn ↗</a></li>
          </ul>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-[var(--font-mono)]">Legal</p>
          <ul class="mt-3 space-y-1.5 text-[var(--color-muted)]">
            <li>CVR 36163771</li>
            <li>{lang === 'da' ? 'København, Danmark' : 'Copenhagen, Denmark'}</li>
          </ul>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] font-[var(--font-mono)]">{d.languageSwitch.label}</p>
          <div class="mt-3"><LanguageSwitcher lang={lang} /></div>
        </div>
      </div>
    </div>
    <div class="rule mt-10 pt-6 border-t border-[var(--color-rule)] flex flex-wrap items-center justify-between gap-3 text-xs text-[var(--color-muted)]">
      <span>© {new Date().getFullYear()} AStyltsvig Consulting</span>
      <span class="font-[var(--font-mono)]">Built with Astro · Cloudflare Pages</span>
    </div>
  </div>
</footer>
