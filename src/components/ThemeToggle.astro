---
import { t, type Lang } from '~/i18n/utils';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const d = t(lang);
---
<button
  type="button"
  id="theme-toggle"
  class="relative h-8 w-8 rounded-full border border-[var(--color-rule)] hover:border-[var(--color-accent)] transition-colors flex items-center justify-center"
  aria-label={d.footer.theme}
>
  <svg class="sun h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
  <svg class="moon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
  #theme-toggle .sun,
  #theme-toggle .moon {
    position: absolute;
    transition: opacity 300ms ease, transform 400ms cubic-bezier(0.2, 0.9, 0.3, 1);
  }
  :global([data-theme="light"]) #theme-toggle .sun { opacity: 1; transform: rotate(0deg) scale(1); }
  :global([data-theme="light"]) #theme-toggle .moon { opacity: 0; transform: rotate(-90deg) scale(0.6); }
  :global([data-theme="dark"]) #theme-toggle .sun  { opacity: 0; transform: rotate(90deg) scale(0.6); }
  :global([data-theme="dark"]) #theme-toggle .moon { opacity: 1; transform: rotate(0deg) scale(1); }
</style>

<script>
  const init = () => {
    const btn = document.getElementById('theme-toggle');
    btn?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') ?? 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (_) {}
    }, { once: false });
  };
  init();
  document.addEventListener('astro:after-swap', init);
</script>
