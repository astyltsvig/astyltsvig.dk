---
import '~/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import GradientBackground from '~/components/GradientBackground.astro';
import { getAlternateUrl, type Lang } from '~/i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  ogType?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  modifiedTime?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  jsonLd,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  image,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://astyltsvig.dk';
const siteName = 'AStyltsvig Consulting';
const author = 'Andreas Sørbye Styltsvig';
const path = canonicalPath ?? Astro.url.pathname;
const canonical = new URL(path, siteUrl).toString();
const enUrl = new URL(getAlternateUrl(path, 'en'), siteUrl).toString();
const daUrl = new URL(getAlternateUrl(path, 'da'), siteUrl).toString();
const ogImage = new URL(image ?? '/og-default.svg', siteUrl).toString();
const ogLocale = lang === 'da' ? 'da_DK' : 'en_GB';
const ogLocaleAlt = lang === 'da' ? 'en_GB' : 'da_DK';
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="publisher" content={siteName} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'} />
    <meta name="googlebot" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1'} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="da" href={daUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={daUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${siteName} — ${author}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' && <meta property="article:author" content={author} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${siteName} — ${author}`} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/logo-mark.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#F7F7F5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111214" media="(prefers-color-scheme: dark)" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-title" content="AStyltsvig" />
    <meta name="application-name" content="AStyltsvig Consulting" />
    <link rel="preconnect" href="https://astyltsvig.dk" />

    {jsonLdArray.map(ld => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}

    <script is:inline>
      (() => {
        const apply = (doc) => {
          try {
            const stored = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const theme = stored ?? (prefersDark ? 'dark' : 'light');
            doc.documentElement.setAttribute('data-theme', theme);
          } catch (_) {}
        };
        apply(document);
        document.addEventListener('astro:before-swap', (event) => apply(event.newDocument));
      })();
    </script>

    <ClientRouter />
  </head>
  <body class="min-h-dvh flex flex-col">
    <GradientBackground />
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:glass focus:px-3 focus:py-2 focus:z-50">
      {lang === 'da' ? 'Spring til indhold' : 'Skip to content'}
    </a>
    <Header lang={lang} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      const init = () => {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        for (const el of document.querySelectorAll('.fade-in:not(.is-visible)')) io.observe(el);
      };
      init();
      document.addEventListener('astro:after-swap', init);
    </script>
  </body>
</html>
