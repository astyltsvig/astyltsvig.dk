---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CaseMeta from '~/components/CaseMeta.astro';
import CaseScreenshot from '~/components/CaseScreenshot.astro';
import ShimmerCTA from '~/components/ShimmerCTA.astro';
import { routes, t } from '~/i18n/utils';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = (await getCollection('casesDa')).sort((a, b) => a.data.order - b.data.order);
  return entries.map((entry, i) => {
    const prev = entries[(i - 1 + entries.length) % entries.length];
    const next = entries[(i + 1) % entries.length];
    return { params: { slug: entry.slug }, props: { entry, prev, next } };
  });
}

interface Props {
  entry: CollectionEntry<'casesDa'>;
  prev: CollectionEntry<'casesDa'>;
  next: CollectionEntry<'casesDa'>;
}
const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const lang = 'da' as const;
const d = t(lang);

const siteUrl = 'https://astyltsvig.dk';
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Forside', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Projekter', item: `${siteUrl}/projekter` },
      { '@type': 'ListItem', position: 3, name: entry.data.client, item: `${siteUrl}/projekter/${entry.slug}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: entry.data.headline,
    headline: entry.data.headline,
    description: entry.data.description,
    author: { '@id': `${siteUrl}/#andreas` },
    creator: { '@id': `${siteUrl}/#andreas` },
    publisher: { '@id': `${siteUrl}/#consulting` },
    about: entry.data.client,
    keywords: entry.data.stack.join(', '),
    inLanguage: 'da',
    url: `${siteUrl}/projekter/${entry.slug}`,
  },
];
---
<BaseLayout
  lang={lang}
  title={`${entry.data.client} — AStyltsvig Consulting`}
  description={entry.data.description}
  jsonLd={jsonLd}
  ogType="article"
>
  <article class="max-w-6xl mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-16">
    <a href={routes.work[lang]} class="fade-in inline-flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M12 7H2M6 3L2 7l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {d.nav.work}
    </a>
    <p class="fade-in mt-10 font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">
      {entry.data.clientUrl ? (
        <a href={entry.data.clientUrl} target="_blank" rel="noopener" class="hover:text-[var(--color-accent)] transition-colors">
          {entry.data.client} ↗
        </a>
      ) : entry.data.client}
    </p>
    <h1 class="fade-in !mt-4 max-w-[22ch] grad-text">{entry.data.headline}</h1>

    <CaseScreenshot
      screenshot={entry.data.screenshot}
      alt={entry.data.screenshotAlt}
      client={entry.data.client}
      clientUrl={entry.data.clientUrl}
    />

    <div class="mt-16 grid gap-10 md:grid-cols-[minmax(0,1fr)_300px] md:gap-16">
      <div class="fade-in prose-body">
        <Content />
      </div>
      <div class="fade-in">
        <CaseMeta
          lang={lang}
          role={entry.data.role}
          period={entry.data.period}
          stack={entry.data.stack}
          statusKey={entry.data.statusKey}
          statusSuffix={entry.data.statusSuffix}
          liveUrl={entry.data.clientUrl}
        />
      </div>
    </div>

    <nav class="mt-20 fade-in grid gap-4 md:grid-cols-2" aria-label="Andre projekter">
      <a href={`/projekter/${prev.slug}`} class="glass p-6 md:p-7 group hover:border-[var(--color-accent)]/40 transition-colors">
        <p class="font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">← Forrige projekt</p>
        <p class="mt-3 font-[var(--font-display)] text-xl md:text-2xl tracking-tight">{prev.data.client}</p>
        <p class="mt-2 text-sm text-[var(--color-muted)] line-clamp-2">{prev.data.headline}</p>
      </a>
      <a href={`/projekter/${next.slug}`} class="glass p-6 md:p-7 group hover:border-[var(--color-accent)]/40 transition-colors md:text-right">
        <p class="font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Næste projekt →</p>
        <p class="mt-3 font-[var(--font-display)] text-xl md:text-2xl tracking-tight">{next.data.client}</p>
        <p class="mt-2 text-sm text-[var(--color-muted)] line-clamp-2">{next.data.headline}</p>
      </a>
    </nav>

    <div class="mt-12 fade-in glass glass-strong p-10 md:p-14 text-center">
      <p class="font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Næste</p>
      <h2 class="!mt-3 max-w-[20ch] mx-auto">Et lignende <span class="grad-text">projekt i tankerne?</span></h2>
      <div class="mt-8 flex justify-center">
        <ShimmerCTA href={routes.contact[lang]} variant="primary">{d.cta.writeToMe}</ShimmerCTA>
      </div>
    </div>
  </article>
</BaseLayout>
