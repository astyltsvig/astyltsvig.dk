---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ShimmerCTA from '~/components/ShimmerCTA.astro';
import { routes, t } from '~/i18n/utils';
const lang = 'da' as const;
const d = t(lang);

const services = [
  {
    n: '00',
    title: 'AI-produktivitet',
    lede: 'Hjælper virksomheder fra ad-hoc ChatGPT-brug til et reelt AI-assisteret workflow der holder i produktion.',
    stack: 'Claude Code · Cursor · Workflow-design · Governance',
    items: [
      'AI-readiness audit af eksisterende workflows, værktøjer og teampraksis',
      'Opsætning af Claude Code eller Cursor med projekt-specifikke konventioner',
      'Kodebase- og proces-hygiejne der holder under AI-redigeringer',
      'Arbejdsdeling: mennesker ejer beslutningerne, AI håndterer eksekveringen',
      'Workshops og parringssessioner for teams og ledelse',
      'Praktiseres dagligt i mit eget ERP-arbejde — ikke teori',
    ],
  },
  {
    n: '01',
    title: 'Webapplikationer',
    lede: 'Fullstack-udvikling af interne systemer, bookingløsninger, ERP og lignende.',
    stack: 'Laravel · Vue · MySQL / PostgreSQL',
    items: [
      'Nye systemer fra arkitektur til produktion',
      'Videreudvikling og vedligeholdelse af eksisterende Laravel/Vue-kodebaser',
      'Integrationer mod eksterne API\'er (betaling, regnskab, kalender, m.m.)',
      'Performance- og databaseoptimering',
    ],
  },
  {
    n: '02',
    title: 'Hjemmesider & CMS-migration',
    lede: 'Nye sites og migration til moderne, statiske stacks. Default: Astro + headless CMS.',
    stack: 'Astro · Sveltia · Decap · Cloudflare Pages',
    items: [
      'Migration fra WordPress til Astro/Sveltia med bevaret indhold og URL-struktur',
      'Nye sites bygget fra bunden i Astro',
      'Deployment-opsætning på Cloudflare Pages med custom domain',
      'Redaktøroplæring og dokumentation',
    ],
  },
  {
    n: '03',
    title: 'Infrastruktur & drift',
    lede: 'DNS, email-autentificering, domæneadministration og serverdrift.',
    stack: 'Hetzner · Cloudflare · SPF/DKIM/DMARC · Google Workspace',
    items: [
      'DNS-migration mellem udbydere (Simply.com, GoDaddy, Cloudflare, Gigahost) uden email-afbrydelse',
      'Opsætning af SPF, DKIM og DMARC',
      'Google Workspace-administration, brugerstyring og forensiske undersøgelser',
      'Serverdrift på Hetzner (Laravel-produktionsservere, backup, SSH-opsætning)',
    ],
  },
  {
    n: '04',
    title: 'Teknisk rådgivning',
    lede: 'For organisationer der står over for større teknologiske beslutninger uden en intern teknisk leder.',
    stack: 'Strategi · Arkitektur · Review',
    items: [
      'Vurdering af eksisterende systemer og leverandøraftaler',
      'Anbefalinger til arkitektur og stack-valg før et udbud',
      'Code review og sikkerhedsgennemgang af eksterne leverancer',
    ],
  },
];
---
<BaseLayout
  lang={lang}
  title="Ydelser — AStyltsvig Consulting"
  description="IT-rådgivning, AI-produktivitet, webapplikationer, CMS-migration, DNS og email-infrastruktur, og teknisk rådgivning."
>
  <article class="max-w-6xl mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-16">
    <p class="fade-in font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Ydelser</p>
    <h1 class="fade-in !mt-4 max-w-[22ch]">
      Opgaver der <span class="grad-text">går dybt</span>.
    </h1>
    <p class="fade-in mt-8 max-w-[60ch] text-lg text-[var(--color-muted)]">
      Løbende aftaler, ikke fastpris-projekter — sådan ender jeg med at bygge det rigtige frem for det aftalte. For mindre, velafgrænsede opgaver (en migration, en DNS-overtagelse) laver jeg gerne et fast estimat.
    </p>

    <div class="mt-16 grid gap-6">
      {services.map((s, i) => (
        <div class="fade-in glass p-7 md:p-10" style={`transition-delay: ${i * 60}ms`}>
          <div class="flex flex-wrap items-baseline justify-between gap-4">
            <div>
              <span class="font-[var(--font-mono)] text-xs text-[var(--color-accent)]">{s.n}</span>
              <h2 class="!mt-2 text-3xl md:text-4xl">{s.title}</h2>
            </div>
            <span class="chip">{s.stack}</span>
          </div>
          <p class="mt-5 text-[var(--color-muted)] max-w-[64ch]">{s.lede}</p>
          <ul class="mt-6 grid gap-2 md:grid-cols-2 text-sm">
            {s.items.map(item => (
              <li class="flex gap-2.5">
                <span class="mt-2 h-1.5 w-1.5 rounded-full bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-2)] flex-none"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-20 fade-in flex justify-center">
      <ShimmerCTA href={routes.contact[lang]} variant="primary">{d.cta.writeToMe}</ShimmerCTA>
    </div>
  </article>
</BaseLayout>
