---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '~/assets/andreas-styltsvig.png';
import { breadcrumbList, webPage } from '~/lib/seo';
const lang = 'da' as const;
const description = 'Andreas Sørbye Styltsvig driver AStyltsvig Consulting som enkeltmandsvirksomhed i København — designer, bygger og drifter enterprise-platforme end-to-end. Foretrukket stack Laravel og Vue, altid tilpasset opgaven.';
const jsonLd = [
  webPage({ lang, path: '/om', name: 'Om Andreas Sørbye Styltsvig — AStyltsvig Consulting', description, type: 'AboutPage' }),
  breadcrumbList([
    { name: 'Forside', path: '/' },
    { name: 'Om', path: '/om' },
  ]),
];
---
<BaseLayout
  lang={lang}
  title="Om Andreas Sørbye Styltsvig — AStyltsvig Consulting København"
  description={description}
  jsonLd={jsonLd}
>
  <article class="max-w-5xl mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-24">

    <!-- Hero -->
    <div class="grid md:grid-cols-[1.2fr_auto] gap-12 md:gap-20 items-center">
      <div>
        <p class="fade-in font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Om</p>
        <h1 class="fade-in !mt-4 max-w-[18ch]">
          Én udvikler. <span class="grad-text">Dybt fokus.</span>
        </h1>
        <p class="fade-in mt-8 max-w-[52ch] text-lg text-[var(--color-muted)] leading-relaxed">
          Jeg hedder Andreas Sørbye Styltsvig og driver <strong class="text-[var(--color-text)] font-semibold">AStyltsvig Consulting</strong> som enkeltmandsvirksomhed fra Vanløse i København.
        </p>
      </div>
      <figure class="fade-in order-first md:order-last w-48 md:w-64 lg:w-72 justify-self-start md:justify-self-end">
        <Image
          src={portrait}
          alt="Portræt af Andreas Sørbye Styltsvig"
          widths={[320, 480, 640, 800]}
          sizes="(min-width: 1024px) 288px, (min-width: 768px) 256px, 192px"
          format="webp"
          quality={82}
          loading="eager"
          class="w-full h-auto rounded-2xl shadow-xl ring-1 ring-white/10"
        />
      </figure>
    </div>

    <!-- Content column: all cards share the same outer boundary -->
    <div class="mt-20 flex flex-col gap-6">

      <!-- Intro bio -->
      <div class="fade-in glass p-8 md:p-12 prose-body !max-w-none">
        <p class="!mt-0 text-lg">
          Jeg har arbejdet med IT og webudvikling i mere end et årti, og praksissens primære fokus er <strong>at bygge og drifte enterprise-grade platforme</strong> — systemer som organisationer driver deres forretning på, år efter år.
        </p>
        <p>
          Min foretrukne stack er Laravel og Vue, men jeg er fleksibel af natur — i praksis tilpasser jeg mig altid den opgave kunden står med og det kodegrundlag der allerede er. Udfaldet er det samme: platforme der holder i produktion over tid.
        </p>
        <p>
          Flere af disse platforme er lige nu i daglig produktion — bookingsystemer, ERP og CRM der understøtter kerneforretning og betjener tusindvis af slutbrugere. Alle bygget og drevet af én udvikler.
        </p>
      </div>

      <!-- Two-column: help / don't -->
      <div class="grid md:grid-cols-2 gap-6">
        <div class="fade-in glass p-8 md:p-10 prose-body !max-w-none">
          <p class="!mt-0 font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-accent)]">Hvad jeg kan hjælpe med</p>
          <h2 class="!mt-3">Sådan skaber jeg <span class="grad-text">værdi</span>.</h2>
          <ul class="!mt-6">
            <li>Designe, bygge og drifte enterprise-platforme på en moderne stack</li>
            <li>Videreudvikling og langsigtet drift af eksisterende kodebaser</li>
            <li>Migrere ældre sites (typisk WordPress) til moderne, statiske stacks</li>
            <li>Administration af infrastruktur</li>
            <li>Rådgive om teknisk arkitektur, leverandørvalg og driftsetup</li>
          </ul>
        </div>
        <div class="fade-in glass p-8 md:p-10 prose-body !max-w-none" style="transition-delay: 80ms">
          <p class="!mt-0 font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-accent)]">Arbejdsform</p>
          <h2 class="!mt-3">Sådan <span class="grad-text">arbejder jeg</span>.</h2>
          <ul class="!mt-6">
            <li>Løbende aftaler frem for fastpris-projekter — det rigtige bliver bygget, ikke det aftalte</li>
            <li>Direkte kontakt fra første samtale til løbende drift — samme person hele vejen</li>
            <li>AI brugt åbent og transparent som en del af workflowet, ikke gemt af vejen</li>
            <li>Få langsigtede kunder frem for mange kortvarige — relationer der løber i år, ikke måneder</li>
            <li>Ejerskab fra arkitektur til drift — én der kender hele stakken når der skal handles hurtigt</li>
          </ul>
        </div>
      </div>

      <!-- Background -->
      <div class="fade-in glass p-8 md:p-12 prose-body !max-w-none">
        <p class="!mt-0 font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Baggrund</p>
        <h2 class="!mt-3">Et årti af <span class="grad-text">bevidst praksis</span>.</h2>
        <p>
          Jeg er <strong>professionsbachelor i softwareudvikling</strong> fra Cphbusiness Lyngby (2019). Karrieren blev for alvor sparket i gang hos Prolike ApS året efter, hvor jeg som konsulent blev udstationeret hos <strong>Oticon</strong> — med ansvar for en stor migration fra on-prem CI/CD (Jenkins) og SVN til en cloudbaseret platform i <strong>Azure DevOps</strong>, med moderne CI/CD-pipelines og Git-baserede workflows.
        </p>
        <p>
          Da Prolike måtte dreje nøglen om som konsekvens af covid, var fundamentet på plads til at fortsætte på egen hånd. Jeg gik fuldtid som freelancer i 2020 og har siden bygget min praksis op omkring få, langvarige kunderelationer.
        </p>
        <p>
          I dag arbejder jeg på en bred vifte af <strong>enterprise-platforme</strong> i tæt, daglig dialog med kunderne — fra kerne-forretningssystemer og realtidsplatforme til løsninger der håndterer tusinder af slutbrugere på tværs af mange organisationer.
        </p>
      </div>

    </div>

  </article>
</BaseLayout>
