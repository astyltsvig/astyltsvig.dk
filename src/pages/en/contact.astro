---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ShimmerCTA from '~/components/ShimmerCTA.astro';
import { breadcrumbList, webPage } from '~/lib/seo';
const lang = 'en' as const;
const email = 'hello@astyltsvig.dk';
const description = 'Contact AStyltsvig Consulting — Andreas Sørbye Styltsvig — about a new project or technical advisory engagement. Email hello@astyltsvig.dk.';
const jsonLd = [
  webPage({ lang, path: '/en/contact', name: 'Contact — AStyltsvig Consulting', description, type: 'ContactPage' }),
  breadcrumbList([
    { name: 'Home', path: '/en/' },
    { name: 'Contact', path: '/en/contact' },
  ]),
];
---
<BaseLayout
  lang={lang}
  title="Contact AStyltsvig Consulting — Andreas Sørbye Styltsvig"
  description={description}
  jsonLd={jsonLd}
>
  <article class="max-w-6xl mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-24">
    <p class="fade-in font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Contact</p>
    <h1 class="fade-in !mt-4 max-w-[16ch]">
      Let's <span class="grad-text">talk.</span>
    </h1>
    <p class="fade-in mt-8 max-w-[56ch] text-lg text-[var(--color-muted)]">
      A short description of what you need, when it needs to ship, and any context I should know.
    </p>

    <div class="fade-in mt-14 glass p-10 md:p-14">
      <p class="font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Write to me</p>
      <a href={`mailto:${email}`} class="block mt-4 font-[var(--font-display)] text-3xl md:text-5xl tracking-tight grad-text break-all">
        {email}
      </a>
      <div class="mt-10 flex flex-wrap gap-4">
        <ShimmerCTA href={`mailto:${email}`} variant="primary">Send an email</ShimmerCTA>
      </div>
    </div>

    <div class="fade-in mt-10 text-sm">
      <div class="glass p-6">
        <p class="font-[var(--font-mono)] text-[10px] uppercase tracking-[0.2em] text-[var(--color-muted)]">CVR</p>
        <p class="mt-2">36163771</p>
      </div>
    </div>
  </article>
</BaseLayout>
