---
import BaseLayout from '~/layouts/BaseLayout.astro';
import CaseCard from '~/components/CaseCard.astro';
import { getCollection } from 'astro:content';
import { breadcrumbList, webPage, SITE_URL } from '~/lib/seo';

const lang = 'en' as const;
const cases = (await getCollection('casesEn')).sort((a, b) => a.data.order - b.data.order);
const description = 'Selected enterprise platforms and projects from AStyltsvig Consulting — Mallard ERP, Book2Go, the SecureLife/Care Pensions CRM, plus selected web engagements.';
const jsonLd = [
  webPage({ lang, path: '/en/work', name: 'Selected work — AStyltsvig Consulting', description, type: 'CollectionPage' }),
  breadcrumbList([
    { name: 'Home', path: '/en/' },
    { name: 'Work', path: '/en/work' },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: cases.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${SITE_URL}/en/work/${c.slug}`,
      name: `${c.data.client} — ${c.data.headline}`,
    })),
  },
];
---
<BaseLayout
  lang={lang}
  title="Selected work — AStyltsvig Consulting (Mallard ERP, Book2Go, SecureLife CRM)"
  description={description}
  jsonLd={jsonLd}
>
  <section class="max-w-6xl mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-10">
    <p class="fade-in font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Work</p>
    <h1 class="fade-in !mt-4 max-w-[18ch]">
      Selected <span class="grad-text">projects</span>.
    </h1>
    <p class="fade-in mt-8 max-w-[60ch] text-lg text-[var(--color-muted)]">
      A sample of what I've built and operated. Several projects aren't public, but the following can be shared.
    </p>
  </section>
  <section class="max-w-6xl mx-auto px-6 md:px-10 pb-24">
    <div class="grid gap-6 md:grid-cols-2">
      {cases.map((c, i) => (
        <CaseCard
          lang={lang}
          slug={c.slug}
          client={c.data.client}
          headline={c.data.headline}
          stack={c.data.stack}
          screenshot={c.data.screenshot}
          screenshotAlt={c.data.screenshotAlt}
          icon={c.data.icon}
          index={i}
        />
      ))}
    </div>
  </section>
</BaseLayout>
