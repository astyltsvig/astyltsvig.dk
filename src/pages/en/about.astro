---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '~/assets/andreas-styltsvig.png';
import { breadcrumbList, webPage } from '~/lib/seo';
const lang = 'en' as const;
const description = 'Andreas Sørbye Styltsvig runs AStyltsvig Consulting as a single-person practice in Copenhagen — designing, building, and operating enterprise platforms end-to-end. Preferred stack Laravel and Vue, always adapted to the brief.';
const jsonLd = [
  webPage({ lang, path: '/en/about', name: 'About Andreas Sørbye Styltsvig — AStyltsvig Consulting', description, type: 'AboutPage' }),
  breadcrumbList([
    { name: 'Home', path: '/en/' },
    { name: 'About', path: '/en/about' },
  ]),
];
---
<BaseLayout
  lang={lang}
  title="About Andreas Sørbye Styltsvig — AStyltsvig Consulting Copenhagen"
  description={description}
  jsonLd={jsonLd}
>
  <article class="max-w-5xl mx-auto px-6 md:px-10 pt-24 md:pt-32 pb-24">

    <!-- Hero -->
    <div class="grid md:grid-cols-[1.2fr_auto] gap-12 md:gap-20 items-center">
      <div>
        <p class="fade-in font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">About</p>
        <h1 class="fade-in !mt-4 max-w-[18ch]">
          One developer. <span class="grad-text">Deep focus.</span>
        </h1>
        <p class="fade-in mt-8 max-w-[52ch] text-lg text-[var(--color-muted)] leading-relaxed">
          I'm Andreas Sørbye Styltsvig, and I run <strong class="text-[var(--color-text)] font-semibold">AStyltsvig Consulting</strong> as a single-person practice out of Vanløse, Copenhagen.
        </p>
      </div>
      <figure class="fade-in order-first md:order-last w-48 md:w-64 lg:w-72 justify-self-start md:justify-self-end">
        <Image
          src={portrait}
          alt="Portrait of Andreas Sørbye Styltsvig"
          widths={[320, 480, 640, 800]}
          sizes="(min-width: 1024px) 288px, (min-width: 768px) 256px, 192px"
          format="webp"
          quality={82}
          loading="eager"
          class="w-full h-auto rounded-2xl shadow-xl ring-1 ring-white/10"
        />
      </figure>
    </div>

    <!-- Content column: all cards share the same outer boundary -->
    <div class="mt-20 flex flex-col gap-6">

      <!-- Intro bio -->
      <div class="fade-in glass p-8 md:p-12 prose-body !max-w-none">
        <p class="!mt-0 text-lg">
          I've worked in IT and web development for more than a decade, and the primary focus of the practice is <strong>building and operating enterprise-grade platforms</strong> — systems that organisations run their business on, year after year.
        </p>
        <p>
          My preferred stack is Laravel and Vue, but I'm flexible by default — in practice, I adapt to whatever the client is working in and whatever codebase is already on the table. The outcome is the same: platforms that hold up in production over time.
        </p>
        <p>
          Several of these platforms are currently in daily production — booking systems, ERP, and CRM supporting core operations and serving thousands of end users. All built and operated by a single developer.
        </p>
      </div>

      <!-- Two-column: help / don't -->
      <div class="grid md:grid-cols-2 gap-6">
        <div class="fade-in glass p-8 md:p-10 prose-body !max-w-none">
          <p class="!mt-0 font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-accent)]">What I help with</p>
          <h2 class="!mt-3">How I can <span class="grad-text">add value</span>.</h2>
          <ul class="!mt-6">
            <li>Designing, building, and operating enterprise platforms on a modern stack</li>
            <li>Continued development and long-term operation of existing codebases</li>
            <li>Migrating older sites (typically WordPress) to modern, static stacks</li>
            <li>Infrastructure administration</li>
            <li>Advising on technical architecture, vendor selection, and operational setup</li>
          </ul>
        </div>
        <div class="fade-in glass p-8 md:p-10 prose-body !max-w-none" style="transition-delay: 80ms">
          <p class="!mt-0 font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-accent)]">Engagement</p>
          <h2 class="!mt-3">How I <span class="grad-text">work</span>.</h2>
          <ul class="!mt-6">
            <li>Rolling engagements over fixed-price projects — I build the right thing, not the agreed thing</li>
            <li>Direct contact from first conversation through ongoing operations — same person all the way</li>
            <li>AI used openly and transparently as part of the workflow, not hidden away</li>
            <li>Codebase and process hygiene first; features only hold up when the foundation does</li>
            <li>Continuous updates over large drops — fixes and features reach users in days, not weeks</li>
            <li>Normal working hours; sprint culture doesn't belong in long-term operation</li>
          </ul>
        </div>
      </div>

      <!-- Background -->
      <div class="fade-in glass p-8 md:p-12 prose-body !max-w-none">
        <p class="!mt-0 font-[var(--font-mono)] text-[10px] uppercase tracking-[0.25em] text-[var(--color-muted)]">Background</p>
        <h2 class="!mt-3">A decade of <span class="grad-text">deliberate practice</span>.</h2>
        <p>
          I hold a <strong>Professional Bachelor's in Software Development</strong> from Copenhagen Business Academy (Cphbusiness Lyngby, 2019). The software career was properly kicked off at Prolike ApS the following year, where I was outsourced to <strong>Oticon</strong> and given responsibility for a major migration from on-prem CI/CD (Jenkins) and SVN to a cloud-based platform on <strong>Azure DevOps</strong> — with modern CI/CD pipelines and Git-based workflows. That foundation is what I went full-time freelance on in 2020.
        </p>
        <p>
          Today I work across a broad range of <strong>enterprise platforms</strong> in close, daily dialogue with clients — from core business systems and real-time platforms to solutions handling thousands of end users across many organisations.
        </p>
      </div>

    </div>

  </article>
</BaseLayout>
